{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand",
    "e2e:open": "cypress open",
    "e2e:run": "cypress run",
    "e2e:docker:run": "docker compose -f docker-compose.e2e.yml --env-file .env.e2e up --build --abort-on-container-exit --exit-code-from cypress",
    "e2e:docker:down": "docker compose -f docker-compose.e2e.yml --env-file .env.e2e down -v"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.97.0",
    "firebase": "^12.12.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cypress": "^15.13.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jest": "^30.3.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
